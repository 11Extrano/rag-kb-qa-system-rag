# ========== MySQL（必配） ==========
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=rag_kb
MYSQL_USER=root
MYSQL_PASSWORD=123456

# ========== 向量化落库：Embedding API（必配，阿里云 DashScope） ==========
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_API_KEY=请替换为你的 DashScope API Key
EMBEDDING_MODEL=text-embedding-v3

# ========== 问答生成：大模型 LLM（必配，未配时问答会失败） ==========
# 示例：阿里云通义 或 其他 OpenAI 兼容接口
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_API_KEY=请替换为你的 Key
# LLM_MODEL=qwen-max
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_API_KEY=请替换为你的 DashScope API Key
LLM_MODEL=qwen-max

# ========== 可选 ==========
# LANCEDB_PATH=.lancedb-data
# EMBEDDING_DIMENSIONS=1536
# RETRIEVAL_TOP_K=5
